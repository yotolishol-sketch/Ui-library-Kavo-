-- ========== Variables ==========
local isOn = false
local points = 0
local floatPart = nil
local floatTween = nil
local followConnection = nil
local checkConnection = nil
local durzConnection = nil
local tauntConnection = nil
local antiAfkConnection = nil
local teamWatchConnection = nil

local leaderstats = player:WaitForChild("leaderstats")
local durzStat = leaderstats:WaitForChild("Durz")
local lastDurzValue = durzStat.Value

local function updatePointLabel()
    pointLabel.Text = "РҒРҜРҹР– Points: " .. points
end

local function getTargetSlot()
    return workspace.DurrWaitingPoint.Container:GetChildren()[2]
end

local function moveHardestToSlot()
    local hardest = workspace.Obbies.AwardParts.Hardest
    local slot = getTargetSlot()
    if hardest and slot then
        hardest.CFrame = slot.CFrame
    end
end

local function removePart()
    if floatTween then floatTween:Cancel() floatTween = nil end
    if followConnection then followConnection:Disconnect() followConnection = nil end
    if floatPart then floatPart:Destroy() floatPart = nil end
end

local function createFloatPart()
    removePart()

    local slot = getTargetSlot()
    if not slot then return end

    local part = Instance.new("Part")
    part.Name = "FloatBase"
    part.Size = Vector3.new(4, 0.5, 4)
    part.Anchored = true
    part.CanCollide = true
    part.BrickColor = BrickColor.new("Bright blue")
    part.Material = Enum.Material.Neon
    part.Transparency = 0.3
    part.CFrame = slot.CFrame
    part.Parent = workspace

    floatPart = part

    task.wait(0.05)
    humanoidRootPart.CFrame = CFrame.new(
        part.Position.X,
        part.Position.Y + 3.5,
        part.Position.Z
    )

    local baseY = part.Position.Y
    local goingUp = true

    local function doFloat()
        if not isOn or not floatPart then return end

        local targetY = goingUp and (baseY + 10) or (baseY - 10)
        local tweenInfo = TweenInfo.new(2, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut)

        floatTween = TweenService:Create(floatPart, tweenInfo, {
            CFrame = CFrame.new(floatPart.Position.X, targetY, floatPart.Position.Z)
        })
        floatTween:Play()

        floatTween.Completed:Connect(function(state)
            if state == Enum.PlaybackState.Completed and isOn and floatPart then
                baseY = floatPart.Position.Y
                goingUp = not goingUp
                doFloat()
            end
        end)
    end

    followConnection = RunService.Heartbeat:Connect(function()
        if floatPart and humanoidRootPart and humanoid then
            humanoid.PlatformStand = true
            local p = floatPart.Position
            humanoidRootPart.CFrame = CFrame.new(p.X, p.Y + 3.5, p.Z)
        end
    end)

    doFloat()
end

local function stopPositionCheck()
    if checkConnection then checkConnection:Disconnect() checkConnection = nil end
end

local function startPositionCheck()
    stopPositionCheck()
    checkConnection = RunService.Heartbeat:Connect(function()
        if not isOn or not floatPart then return end
        local slot = getTargetSlot()
        if not slot then return end
        local dist = (floatPart.Position - slot.Position).Magnitude
        if dist > 30 then
            removePart()
            task.wait(0.1)
            createFloatPart()
        end
    end)
end

local function stopPointTimer()
    if durzConnection then durzConnection:Disconnect() durzConnection = nil end
end

local function startPointTimer()
    stopPointTimer()
    durzConnection = durzStat.Changed:Connect(function(newValue)
        local diff = newValue - lastDurzValue
        if diff > 0 then
            points = points + diff
            updatePointLabel()
        end
        lastDurzValue = newValue
    end)
end

local function stopTauntLoop()
    if tauntConnection then tauntConnection:Disconnect() tauntConnection = nil end
end

local function startTauntLoop()
    stopTauntLoop()
    local elapsed = 0
    tauntConnection = RunService.Heartbeat:Connect(function(dt)
        elapsed = elapsed + dt
        if elapsed < 0.5 then return end
        elapsed = 0

        local taunt = player.Backpack:FindFirstChild("Taunt")
        if not taunt then
            taunt = character and character:FindFirstChild("Taunt")
        end

        if taunt then
            humanoid:EquipTool(taunt)
            task.wait(0.05)
            local equipped = character and character:FindFirstChild("Taunt")
            if equipped and equipped:IsA("Tool") then
                equipped:Activate()
            end
        end
    end)
end

local function stopAntiAfk()
    if antiAfkConnection then antiAfkConnection:Disconnect() antiAfkConnection = nil end
end

local function startAntiAfk()
    stopAntiAfk()
    local elapsed = 0
    antiAfkConnection = RunService.Heartbeat:Connect(function(dt)
        elapsed = elapsed + dt
        if elapsed < 60 then return end
        elapsed = 0

        local screenX = workspace.CurrentCamera.ViewportSize.X / 2
        local screenY = workspace.CurrentCamera.ViewportSize.Y / 2

        VirtualInputManager:SendMouseButtonEvent(screenX, screenY, 0, true, game, 1)
        task.wait(0.1)
        VirtualInputManager:SendMouseButtonEvent(screenX, screenY, 0, false, game, 1)
    end)
end

local function stopTeamWatch()
    if teamWatchConnection then
        teamWatchConnection:Disconnect()
        teamWatchConnection = nil
    end
end

-- ========== Team Watcher ==========
local function startTeamWatch()
    stopTeamWatch()
    teamWatchConnection = player:GetPropertyChangedSignal("Team"):Connect(function()
        local team = player.Team

        if team and team.Name == "Durr" then
            -- СҖв••Р‘СҖв••РӨ OFF СҖв••Р‘СҖв•ЈРҳСҖв••РҪСҖв••Р©
            isOn = false
            toggleButton.Text = "OFF"
            toggleButton.BackgroundColor3 = Color3.fromRGB(50, 200, 80)
            removePart()
            stopPositionCheck()
            stopPointTimer()
            stopTauntLoop()
            stopAntiAfk()
            if humanoid then humanoid.PlatformStand = false end

            -- СҖв•ЈР‘СҖв••РөСҖв•ЈРҷСҖв••Р·СҖв••Р”СҖв•ЈРҳСҖв••РҪСҖв••РІ TP СҖв••РөСҖв••Р— -9999
            task.wait(0.1)
            if humanoidRootPart then
                humanoidRootPart.CFrame = CFrame.new(
                    humanoidRootPart.Position.X,
                    -9999,
                    humanoidRootPart.Position.Z
                )
            end

        elseif team and (team.Name == "Alive" or team.Name == "Dead") then
            -- СҖв••Р§СҖв••в•ЎСҖв••РұСҖв••Р‘СҖв••РөСҖв••в–’СҖв••РӘСҖв••РұСҖв••в–“СҖв••Р«СҖв••Р‘СҖв••РҘСҖв••в”Ө СӮР–Рў СҖв••Р‘СҖв••РӨ ON СҖв••РҪСҖв••в–’СҖв••РҘСҖв•ЈР’СҖв••Р©СҖв••РұСҖв••в–’СҖв••РҘСҖв••в”Ө
            if not isOn then
                isOn = true
                toggleButton.Text = "ON"
                toggleButton.BackgroundColor3 = Color3.fromRGB(200, 50, 50)
                moveHardestToSlot()
                task.wait(0.2)
                createFloatPart()
                startPositionCheck()
                startPointTimer()
                startTauntLoop()
                startAntiAfk()
            end
        end
    end)
end

-- ========== Toggle Button ==========
toggleButton.MouseButton1Click:Connect(function()
    isOn = not isOn

    if isOn then
        toggleButton.Text = "ON"
        toggleButton.BackgroundColor3 = Color3.fromRGB(200, 50, 50)

        moveHardestToSlot()
        task.wait(0.2)
        createFloatPart()
        startPositionCheck()
        startPointTimer()
        startTeamWatch()
        startTauntLoop()
        startAntiAfk()
    else
        toggleButton.Text = "OFF"
        toggleButton.BackgroundColor3 = Color3.fromRGB(50, 200, 80)

        removePart()
        stopPositionCheck()
        stopPointTimer()
        stopTeamWatch()
        stopTauntLoop()
        stopAntiAfk()

        if humanoid then humanoid.PlatformStand = false end
    end
end)
